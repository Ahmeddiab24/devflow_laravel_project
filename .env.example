APP_NAME=DevFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─────────────────────────────────────────
# DATABASE  (Docker service: mysql)
# ─────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=devflow
DB_USERNAME=devflow
DB_PASSWORD=secret

# ─────────────────────────────────────────
# CACHE / SESSION / QUEUE  (Docker service: redis)
# ─────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─────────────────────────────────────────
# MAIL  (Use Mailpit in Docker for local dev)
# ─────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@devflow.local"
MAIL_FROM_NAME="${APP_NAME}"

# ─────────────────────────────────────────
# AWS / S3 (optional, for storage practice)
# ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─────────────────────────────────────────
# SANCTUM (API auth)
# ─────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─────────────────────────────────────────
# MONITORING (Prometheus metrics endpoint)
# ─────────────────────────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_NAMESPACE=devflow
